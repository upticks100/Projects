#!/usr/bin/env python3
"""
compare_pure_cp_struct_vs_ridge_L2_L4.py

Pure CP (Structured) vs Ridge baseline, for BOTH lookback periods L=2 and L=4
(and for both MODE=LEVELS/SURPRISE), using the SAME data prep + CV + pooled
mask-aware R² used in Pure_CP_Structured.py.

No command-line args. Just run:
  python compare_pure_cp_struct_vs_ridge_L2_L4.py
"""

import os
from pathlib import Path
from typing import Optional, List, Tuple

import joblib
import numpy as np
import optuna
import tensorly as tl

from sklearn.model_selection import TimeSeriesSplit
from sklearn.linear_model import RidgeCV
from tensorly.regression.cp_regression import CPRegressor

# --- thread safety (match your scripts) ---
os.environ["OMP_NUM_THREADS"] = "1"
os.environ["MKL_NUM_THREADS"] = "1"
os.environ["OPENBLAS_NUM_THREADS"] = "1"

SEED = 42
MIN_VALID_ENTRIES = 1000
MIN_OBS_PER_FEAT = 25

MODES = ["LEVELS", "SURPRISE"]
LOOKBACKS = [2, 4]

FILE_MAP = {
    "LEVELS":   {2: "tensor_levels_L2.pkl", 4: "tensor_levels_L4.pkl"},
    "SURPRISE": {2: "tensor_L2_R40_20_2.pkl", 4: "tensor_L4_R40_20_4.pkl"},
}

RIDGE_ALPHAS = np.array([0.1, 1.0, 10.0, 100.0, 1000.0], dtype=float)

def evaluate_model(y_true: np.ndarray, y_pred: np.ndarray, mask: np.ndarray) -> Optional[float]:
    """Pooled, mask-aware R² (same definition used across your scripts)."""
    y_t, y_p, m = y_true.flatten(), y_pred.flatten(), mask.flatten()
    valid = m > 0
    if np.sum(valid) < MIN_VALID_ENTRIES:
        return None
    clean_t, clean_p = y_t[valid], y_p[valid]
    sst = np.sum((clean_t - np.mean(clean_t)) ** 2)
    if sst <= 1e-8:
        return None
    return 1.0 - np.sum((clean_t - clean_p) ** 2) / sst

def get_best_trial_for(study: optuna.Study, mode: str, L: int) -> optuna.trial.FrozenTrial:
    best = None
    for t in study.get_trials(deepcopy=False):
        if t.value is None:
            continue
        if t.params.get("MODE") != mode:
            continue
        if int(t.params.get("L")) != int(L):
            continue
        if (best is None) or (t.value > best.value):
            best = t
    if best is None:
        raise RuntimeError(f"No COMPLETE trials for MODE={mode}, L={L}")
    return best

def run_one_combo(study: optuna.Study, cache_path: Path, mode: str, L: int) -> Tuple[float, float, float]:
    cache = joblib.load(cache_path)
    X_all = cache["X"]     # (T, Firms, Features, L)
    Y_all = cache["Y"]     # (T, Firms, Features)
    M_all = cache["Mask"]  # (T, Firms, Features)

    bt = get_best_trial_for(study, mode, L)

    rank_reg = int(bt.params["RANK_REGRESS"])
    reg_w = float(bt.params["REG_W"])
    # keep this minimal but tolerant to older param naming
    use_rms = bool(bt.params.get("USE_RMS_SCALING", bt.params.get("RMS_Scaling", False)))

    print(f"\n=== PURE CP STRUCT vs RIDGE | MODE={mode} L={L} ===")
    print(
        f"Best trial #{bt.number} value={bt.value:.5f} | "
        f"rank={rank_reg} reg_w={reg_w:.6g} rms={use_rms}"
    )

    # CV setup (same pattern as your scripts)
    tscv = TimeSeriesSplit(n_splits=3)
    split_idx = int(0.8 * len(X_all))
    X_cv, Y_cv, M_cv = X_all[:split_idx], Y_all[:split_idx], M_all[:split_idx]

    ridge_scores: List[float] = []
    cp_scores: List[float] = []

    for fold_idx, (tr_idx, val_idx) in enumerate(tscv.split(X_cv)):
        X_tr, Y_tr, M_tr = X_cv[tr_idx], Y_cv[tr_idx], M_cv[tr_idx]
        X_val, Y_val, M_val = X_cv[val_idx], Y_cv[val_idx], M_cv[val_idx]

        n_tr_t, n_f, n_feat, _ = X_tr.shape

        # 1) mask-aware mean over (time, firm)
        denom = M_tr.sum(axis=(0, 1)) + 1e-8
        y_mean_tr = (Y_tr * M_tr).sum(axis=(0, 1)) / denom  # (Feat,)

        # -------------------------
        # Ridge baseline (structured)
        # -------------------------
        X_tr_ridge_all = X_tr.transpose(0, 1, 3, 2).reshape(n_tr_t * n_f, -1)
        Y_tr_f = Y_tr.reshape(n_tr_t * n_f, n_feat)
        M_tr_f = M_tr.reshape(n_tr_t * n_f, n_feat)
        f_mask_tr = M_tr_f.any(axis=1)

        ridge_models: List[Optional[RidgeCV]] = []
        for j in range(n_feat):
            obs_idx = (M_tr_f[:, j] > 0) & f_mask_tr
            if obs_idx.sum() < MIN_OBS_PER_FEAT:
                ridge_models.append(None)
                continue
            rg = RidgeCV(alphas=RIDGE_ALPHAS, fit_intercept=False, cv=None)
            rg.fit(X_tr_ridge_all[obs_idx], Y_tr_f[obs_idx, j] - y_mean_tr[j])
            ridge_models.append(rg)

        n_val_t = X_val.shape[0]
        X_val_ridge_all = X_val.transpose(0, 1, 3, 2).reshape(n_val_t * n_f, -1)
        y_ridge_val_f = np.zeros((n_val_t * n_f, n_feat), dtype=float)
        for j, rg in enumerate(ridge_models):
            if rg is not None:
                y_ridge_val_f[:, j] = rg.predict(X_val_ridge_all)

        y_ridge_val_3d = y_ridge_val_f.reshape(n_val_t, n_f, n_feat)
        y_ridge_final = y_ridge_val_3d + y_mean_tr
        r2_ridge = evaluate_model(Y_val, y_ridge_final, M_val)

        # -------------------------
        # Pure CP Structured
        # -------------------------
        Y_tr_centered = (Y_tr - y_mean_tr) * M_tr

        if use_rms:
            y_obs = Y_tr_centered[M_tr > 0]
            if y_obs.size < MIN_VALID_ENTRIES:
                print(f"Fold {fold_idx}: pruned-like (too few obs for CP RMS).")
                ridge_scores.append(np.nan)
                cp_scores.append(np.nan)
                continue
            y_rms = float(np.sqrt(np.mean(y_obs ** 2)))
            if (not np.isfinite(y_rms)) or (y_rms < 1e-4):
                print(f"Fold {fold_idx}: pruned-like (invalid CP RMS).")
                ridge_scores.append(np.nan)
                cp_scores.append(np.nan)
                continue
            Y_target_scaled = Y_tr_centered / (y_rms + 1e-8)
        else:
            y_rms = 1.0
            Y_target_scaled = Y_tr_centered

        cp_model = CPRegressor(
            weight_rank=rank_reg,
            reg_W=reg_w,
            n_iter_max=150,
            random_state=SEED,
        )
        cp_model.fit(X_tr, Y_target_scaled)

        preds_scaled = cp_model.predict(X_val)
        y_cp_final = (preds_scaled * y_rms) + y_mean_tr
        r2_cp = evaluate_model(Y_val, y_cp_final, M_val)

        ridge_score = max(r2_ridge, -1.0) if r2_ridge is not None else np.nan
        cp_score    = max(r2_cp, -1.0)    if r2_cp is not None else np.nan

        ridge_scores.append(ridge_score)
        cp_scores.append(cp_score)

        print(
            f"Fold {fold_idx}: Ridge R2={ridge_score: .5f}   "
            f"PureCP R2={cp_score: .5f}   Delta={cp_score - ridge_score: .5f}"
        )

    ridge_mean = float(np.nanmean(ridge_scores))
    cp_mean = float(np.nanmean(cp_scores))
    delta = cp_mean - ridge_mean

    print(f"\nSUMMARY | MODE={mode} L={L}")
    print(f"Ridge mean CV R2:    {ridge_mean:.5f}")
    print(f"PureCP mean CV R2:   {cp_mean:.5f}")
    print(f"Delta (CP-Ridge):    {delta:.5f}")

    return ridge_mean, cp_mean, delta

def main():
    tl.set_backend("numpy")
    np.random.seed(SEED)

    here = Path(__file__).resolve().parent
    cache_dir = here / "tensor_cache"
    db_path = Path("/student/mcnama53/research_pure_struct.db")
    study_name = "research_pure_struct_v1"

    storage = f"sqlite:///{db_path.as_posix()}"
    study = optuna.load_study(study_name=study_name, storage=storage)

    summary = []

    for mode in MODES:
        for L in LOOKBACKS:
            cache_file = cache_dir / FILE_MAP[mode][L]
            if not cache_file.exists():
                print(f"[SKIP] Missing cache: {cache_file}")
                continue
            try:
                ridge_mean, cp_mean, delta = run_one_combo(study, cache_file, mode, L)
                summary.append((mode, L, ridge_mean, cp_mean, delta))
            except Exception as e:
                print(f"[FAIL] MODE={mode} L={L}: {e}")

    print("\n===== FINAL SUMMARY (Pure CP Structured vs Ridge) =====")
    print(f"{'MODE':<9} {'L':<2} {'RIDGE':>10} {'CP':>10} {'DELTA':>10}")
    print("-" * 52)
    for mode, L, ridge_mean, cp_mean, delta in summary:
        print(f"{mode:<9} {L:<2d} {ridge_mean:>10.5f} {cp_mean:>10.5f} {delta:>10.5f}")

if __name__ == "__main__":
    main()
